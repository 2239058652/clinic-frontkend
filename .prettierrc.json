{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": false,
    "printWidth": 120,
    "tabWidth": 4,
    "useTabs": false,
    "vueIndentScriptAndStyle": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "bracketSpacing": true,
    "trailingComma": "none",
    "jsxSingleQuote": false,
    "arrowParens": "always",
    "insertPragma": false,
    "requirePragma": false,
    "proseWrap": "never",
    "htmlWhitespaceSensitivity": "ignore",
    "endOfLine": "auto",
    "rangeStart": 0
}